# ============================================================
# AgtOpen Environment Variables
# ============================================================
#
# LOCAL DEV: Required for local development. These values work
#   out of the box with `docker compose up -d`.
#
# OPTIONAL (Cloud Services): Only needed if you use specific
#   features. Commented out by default -- uncomment and fill
#   in when you need them.
# ============================================================

# ----------------------------------------------------------
# LOCAL DEV -- Required
# ----------------------------------------------------------

# PostgreSQL (matches docker-compose.yml defaults)
DATABASE_URL=postgresql://agtopen:agtopen_dev@localhost:5432/agtopen

# Auth tokens (change these in production)
JWT_SECRET=dev-secret-change-me-in-production
JWT_REFRESH_SECRET=dev-refresh-secret-change-me

# Runtime
NODE_ENV=development

# CORS (comma-separated origins allowed to access the API)
CORS_ORIGINS=http://localhost:3000,https://agtopen.com,https://www.agtopen.com

# Frontend URLs
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3002

# ----------------------------------------------------------
# OPTIONAL -- Cloud Services
# ----------------------------------------------------------

## OpenAI (only needed if running agent-engine)
## OPENAI_API_KEY=sk-xxx

## Upstash Redis (local Redis via Docker is used by default)
## UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
## UPSTASH_REDIS_REST_TOKEN=AXxx

## Cloudflare R2 (only needed for file uploads)
## CLOUDFLARE_ACCOUNT_ID=xxx
## R2_ACCESS_KEY_ID=xxx
## R2_SECRET_ACCESS_KEY=xxx
## R2_BUCKET_NAME=agto-storage
## R2_PUBLIC_URL=https://storage.agtopen.com

## Resend (only needed for email notifications)
## RESEND_API_KEY=re_xxx

## Neon PostgreSQL (only needed for Neon cloud database, not local dev)
## DATABASE_URL_UNPOOLED=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/agtopen?sslmode=require
